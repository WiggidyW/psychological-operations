{
  "manifest_version": 3,
  "name": "Psychological Operations Capture",
  "version": "0.1.0",
  "description": "Capture For-You tweets into the local psyop DB.",
  "key": "",
  "permissions": ["activeTab", "scripting", "storage", "nativeMessaging"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://console.x.com/*",
    "https://developer.x.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Psychological Operations"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://console.x.com/*", "https://developer.x.com/*"],
      "js": ["billing_script.js"],
      "run_at": "document_idle"
    }
  ]
}
