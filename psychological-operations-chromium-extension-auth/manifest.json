{
  "manifest_version": 3,
  "name": "Psychological Operations: X-App Auth",
  "version": "0.99.0",
  "description": "Capture the master X-App credentials from console.x.com / developer.x.com into ~/.psychological-operations/x_app.json.",
  "key": "",
  "permissions": ["activeTab", "storage", "nativeMessaging"],
  "host_permissions": [
    "https://developer.x.com/*",
    "https://console.x.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Psychological Operations: X-App Auth"
  }
}
